<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#C2B3E3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="36dp"
        android:paddingBottom="36dp">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="220dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="40dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/own_my_way_logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nome"
            android:textColor="#3E3E3E"
            android:textSize="20sp"
            android:layout_marginStart="10dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="22dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="exemplo"
            android:inputType="textPersonName"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#333333"
            android:textColorHint="#9A9A9A" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E-mail"
            android:textColor="#3E3E3E"
            android:textSize="20sp"
            android:layout_marginStart="10dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="22dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="exemplo@123.com"
            android:inputType="textEmailAddress"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#333333"
            android:textColorHint="#9A9A9A" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Senha"
            android:textColor="#3E3E3E"
            android:textSize="20sp"
            android:layout_marginStart="10dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="22dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="Digite pelo menos 6 caracteres"
            android:inputType="textPassword"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#333333"
            android:textColorHint="#9A9A9A" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirmar senha"
            android:textColor="#3E3E3E"
            android:textSize="20sp"
            android:layout_marginStart="10dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="30dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="Digite os mesmos caracteres"
            android:inputType="textPassword"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#333333"
            android:textColorHint="#9A9A9A" />

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="80dp"
            android:background="@drawable/bg_button_primary"
            android:text="Entrar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="20sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Já tenho uma conta,"
            android:textColor="#3E3E3E"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="login"
            android:textColor="#4A36D9"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingTop="4dp" />

    </LinearLayout>
</ScrollView>