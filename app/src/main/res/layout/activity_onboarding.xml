<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Conte-nos mais sobre você!"
            android:textColor="@color/omw_purple_mid"
            android:textSize="28sp"
            android:fontFamily="@font/playfair_display_bold"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Isso nos ajudará a personalizar suas jornadas."
            android:textColor="#666666"
            android:textSize="16sp" />

        <!-- Seção: Interesses -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="O que você mais gosta?"
            android:textColor="@color/omw_purple_main"
            android:textStyle="bold" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupInterests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:chipSpacingHorizontal="8dp">

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipBackgroundColor="@color/omw_white"
                app:chipStrokeColor="@color/omw_purple_light"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/omw_purple_mid"
                android:text="Museus" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipBackgroundColor="@color/omw_white"
                app:chipStrokeColor="@color/omw_purple_light"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/omw_purple_mid"
                android:text="Trilhas" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipBackgroundColor="@color/omw_white"
                app:chipStrokeColor="@color/omw_purple_light"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/omw_purple_mid"
                android:text="Gastronomia" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipBackgroundColor="@color/omw_white"
                app:chipStrokeColor="@color/omw_purple_light"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/omw_purple_mid"
                android:text="Vida Noturna" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:chipBackgroundColor="@color/omw_white"
                app:chipStrokeColor="@color/omw_purple_light"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/omw_purple_mid"
                android:text="Compras" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Seção: Orçamento -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Quanto está disposto a gastar?"
            android:textColor="@color/omw_purple_main"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/radioGroupBudget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radioBudgetLow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/omw_purple_light"
                android:text="$ (Econômico)" />

            <RadioButton
                android:id="@+id/radioBudgetMid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/omw_purple_light"
                android:checked="true"
                android:text="$$ (Médio)" />

            <RadioButton
                android:id="@+id/radioBudgetHigh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/omw_purple_light"
                android:text="$$$ (Luxo)" />
        </RadioGroup>

        <!-- Botão Finalizar -->
        <Button
            android:id="@+id/btnFinishOnboarding"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="48dp"
            android:backgroundTint="@color/omw_purple_mid"
            android:text="Finalizar e Começar"
            android:fontFamily="@font/playfair_display_bold"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textColor="@color/omw_white"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>
